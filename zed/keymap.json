[
  {
    "bindings": {
      "cmd-shift-k": "projects::OpenRecent",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      ", j": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      ", a": "command_palette::Toggle",
      ", d": "vim::ScrollDown",
      ", e": "tab_switcher::ToggleAll",
      ", f": "file_finder::Toggle",
      ", j": "project_panel::ToggleFocus",
      ", m": "editor::Format",
      ", r": "editor::Rename",
      ", s": "workspace::SaveWithoutFormat",
      ", u": "vim::ScrollUp",
      ", z": "workspace::ToggleCenteredLayout",
      ", w v": "pane::SplitRight",
      ", w s": "pane::SplitDown",
      ", w o": "workspace::CloseInactiveTabsAndPanes",
      ", w q": "pane::CloseAllItems",
      ", w l": "workspace::ActivatePaneRight",
      ", w h": "workspace::ActivatePaneLeft",
      ", w k": "workspace::ActivatePaneUp",
      ", w j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "A": ["workspace::SendKeystrokes", "g A"],
      "I": ["workspace::SendKeystrokes", "g I"],
    },
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-j": "workspace::ToggleBottomDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-j": "workspace::ToggleLeftDock",
    },
  },
  {
    "bindings": {
      "ctrl-shift-k": "workspace::Open",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-n": [
        "editor::SelectNext",
        {
          "replace_newest": false,
        },
      ],
    },
  },
]
