{
  "outline_panel": {
    "indent_guides": {
      "show": "always"
    },
    "indent_size": 14.0
  },
  "disable_ai": true,
  "format_on_save": "off",
  "theme": "Catppuccin Frappé",
  "buffer_font_size": 16.0,
  "ui_font_size": 14,
  "vim_mode": true,
  "ui_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  // "ui_font_family": "Iosevka Nerd Font Mono",
  // "buffer_font_family": "Iosevka Nerd Font Mono",
  "relative_line_numbers": "enabled",
  "tab_size": 2,
  "buffer_line_height": "standard",
  "indent_guides": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
    "folds": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "tab_bar": {
    "show": false,
  },
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false,
    },
  },
  "project_panel": {
    "indent_guides": {
      "show": "always"
    },
    "indent_size": 14.0,
    "git_status": false,
  },
  "scrollbar": {
    "git_diff": false,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "vertical_scroll_margin": 0,
}
